
DEBUG=True
SECRET_KEY=change-me-in-production-12345
DATABASE_URL=postgis://root:motdepasse@127.0.0.1:5432/illeto_db
ALLOWED_HOSTS=localhost,127.0.0.1

ILLETO_MAPBOX_ACCESS_TOKEN=


# Export Atlas HD (Playwright). Après activation : pip install playwright && playwright install chromium
ILLETO_PLAYWRIGHT_EXPORT_ENABLED=True
ILLETO_ATLAS_EXPORT_CACHE_DIR=var/atlas_export_cache
ILLETO_ATLAS_EXPORT_CACHE_TTL=86400
ILLETO_EXPORT_MAX_CONCURRENT=1

ILLETO_ATLAS_PDF_BADGE_PATH=static/img/Filigrane.png

# Imports géographiques (chemins par défaut si les commandes sont lancées sans argument fichier)
ILLETO_HDX_ADM1_PATH= data/ben_admin1.geojson
ILLETO_HDX_ADM2_PATH= data/ben_admin2.geojson
ILLETO_HDX_ADM3_PATH= data/ben_admin3.geojson
ILLETO_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
ILLETO_OSM_DISTRICTS_PATH= data/osm_districts.geojson
ILLETO_POI_GEOJSON_PATH= data/poi.geojson
ILLETO_HYDRO_GEOJSON_PATH= data/hydro.geojson
ILLETO_VECTOR_IMPORT_DEFAULT_PATH= data/communes.geojson

# Inclure les communes « placeholder » dans certaines API carto (voir code)
ILLETO_GEO_INCLUDE_PLACEHOLDER_COMMUNES=False

PYTHON_VERSION=3.11.0